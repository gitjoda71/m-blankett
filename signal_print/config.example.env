# Signal-grupp att lyssna på (hämtas från signal-cli)
SIGNAL_GROUP_ID=grupp-id-här

# Skrivarnamn ("default" = systemets standardskrivare)
PRINTER_NAME=default

# Utskriftsmetod: auto | lp | sumatrapdf | osprint
PRINTER_METHOD=auto

# Mapp för genererade PDF:er
OUTPUT_DIR=./output

# Port för webhook-servern
PORT=8080
